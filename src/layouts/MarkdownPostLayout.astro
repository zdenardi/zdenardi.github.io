---
import Footer from "@/components/Footer";
import Layout from "./Layout.astro";
import GlassHeader from "@/components/GlassHeader";
const { frontmatter } = Astro.props;

---
<Layout>
    <GlassHeader client:only="react" />
    <main class="min-h-screen max-w-3xl mx-auto py-10">
        {/* Display Title */}
        <header class="text-3xl font-bold mb-8 text-center md:text-left underline">{frontmatter.title || "Untitled Post"}</header>

        {/* Metadata below title (optional grouping) */}
        <p class="text-sm text-gray-500 mb-3">Published on {frontmatter.pubDate?.toString().slice(0, 10)}</p>
        <div class="mb-4">
            <em class="block">{frontmatter.description}</em>
            <span class="text-sm text-gray-600 block mt-1">Written by: {frontmatter.author}</span>
        </div>

        <!-- Slot will render the content from MarkdownPostLayout.astro -->
        <div class="prose lg:prose-lg dark:prose-invert max-w-none">
            <slot />
        </div>
    </main>
    <Footer client:only="react" />

</Layout>