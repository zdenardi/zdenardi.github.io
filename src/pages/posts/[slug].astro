---
import type { GetStaticPaths } from "astro";
import MarkdownPostLayout from '../../layouts/MarkdownPostLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';


export async function getStaticPaths() {
  const allPosts = await getCollection('post')

  return allPosts.map((post) => ({
    params: { slug:post.id }, // The 'slug' must match the filename structure (e.g., post-1)
    props: { postEntry: post } // Pass the entire collection entry to the page component props
  }));
}

// 3. Define the Props that this dynamic page expects
interface Props {
  postEntry: CollectionEntry<'post'>;
}

const { postEntry } = Astro.props;
const { Content } = await render(postEntry);
---
<MarkdownPostLayout
 post={postEntry.data}
>
    <Content />
</MarkdownPostLayout>